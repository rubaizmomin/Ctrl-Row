<idea-plugin>

    <id>com.rubaizmomin.csvsuiterunner</id>
    <name>CSV Suite Runner</name>
    <vendor email="rubaizmomin@gmail.com">Rubaiz Momin</vendor>
    <description>
        <![CDATA[
        Run selected TestNG CSV data rows directly from IntelliJ IDEA.
        ]]>
    </description>
    <idea-version since-build="251"/>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
                id="HelloWorld"
                class="com.rubaizmomin.CsvSuiteRunner.actions.HelloWorldAction"
        >

            <add-to-group
                    group-id="ProjectViewPopupMenu"
                    anchor="last"/>

        </action>
    </actions>
    <resource-bundle>messages.MyMessageBundle</resource-bundle>

</idea-plugin>